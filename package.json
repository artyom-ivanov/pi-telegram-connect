{
  "name": "@artyomspace/pi-telegram-connect",
  "version": "0.1.0",
  "description": "Telegram bridge for the Pi coding agent: pair once, then chat with your local pi-CLI agent from your phone.",
  "license": "MIT",
  "author": "artyomspace",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": { "node": ">=20.6.0" },
  "keywords": [
    "pi-cli",
    "pi-coding-agent",
    "pi-extension",
    "pi-package",
    "telegram",
    "telegram-bot",
    "grammy",
    "ai-agent",
    "llm",
    "extension"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artyom-ivanov/pi-telegram-connect.git"
  },
  "homepage": "https://github.com/artyom-ivanov/pi-telegram-connect#readme",
  "bugs": {
    "url": "https://github.com/artyom-ivanov/pi-telegram-connect/issues"
  },
  "pi": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "grammy": "^1.30.0",
    "@grammyjs/runner": "^2.0.3",
    "marked": "^14.1.0",
    "proper-lockfile": "^4.1.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "^0.32.0"
  }
}
